RAPIDAPI_KEY=your_api_key_here

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=your_email@gmail.com

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── MVP Web API (Phase 1) ─────────────────────────────────────────────────────

# Admin login for POST /api/v1/auth/login
ADMIN_EMAIL=your@email.com

# Option A — bcrypt hash (production):
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Option B — plaintext (development only, ignored when hash is set):
ADMIN_PASSWORD=

# HS256 JWT signing secret (32+ chars):
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_TTL_HOURS=24

# Set to "true" when behind HTTPS
COOKIE_SECURE=false

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Comma-separated keywords to hard-exclude from job results
EXCLUDE_KEYWORDS=

# ── Rico AI reasoning + scoring ───────────────────────────────────────────────

# OpenAI API key — powers the conversational reply path in /api/v1/rico/chat
# when the user sends an open-ended message. When unset, Rico falls back to a
# safe templated response. Canonical name expected by the code.
# (Legacy alias OPEN_AI_API is read as a fallback for backwards compatibility.)
OPENAI_API_KEY=

# OpenAI model used by RicoOpenAIAgent. Optional. Default: gpt-4.1-mini
RICO_OPENAI_MODEL=gpt-4.1-mini

# HuggingFace API token — used by src/llm_scorer.py for embedding-based
# semantic job scoring and by src/job_agent.py for HF text generation.
# NOT used in the chat reply path.
HF_TOKEN=

# ── Jotform onboarding webhook ────────────────────────────────────────────────

# Active Jotform onboarding form ID. The webhook validates submissions against
# this value (comma-separated list also supported).
JOTFORM_FORM_ID=

# Optional shared secret. When set, /api/v1/rico/webhooks/jotform fail-closes
# (returns 403) on missing or wrong secret. Send via header X-Jotform-Signature
# or query param ?secret=...
JOTFORM_WEBHOOK_SECRET=

# Optional Jotform API key for retrieving uploaded CV files. Not required for
# the basic webhook → DB profile flow.
JOTFORM_API_KEY=

# ── Rico AI provider ──────────────────────────────────────────────────────────

# Primary AI provider. Default: hf (Hugging Face, zero OpenAI cost).
# Set to 'openai' only for premium mode when OPENAI_API_KEY is present.
RICO_AI_PROVIDER=hf

# Hugging Face Inference API token (canonical key name).
# Get one free at: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Optional: override default models.
# Text generation (default: HuggingFaceH4/zephyr-7b-beta)
HF_TEXT_MODEL=

# Zero-shot classification (default: facebook/bart-large-mnli)
HF_CLASSIFICATION_MODEL=

# Summarization (default: facebook/bart-large-cnn)
HF_SUMMARIZATION_MODEL=

# ── GitHub webhook ────────────────────────────────────────────────────────────

# Secret configured in GitHub repo → Settings → Webhooks.
# When set, POST /api/v1/rico/webhooks/github validates X-Hub-Signature-256
# (HMAC-SHA256). Leave blank in dev to skip signature verification.
GITHUB_WEBHOOK_SECRET=

# ── Legacy ────────────────────────────────────────────────────────────────────

# Legacy control server key (backward compat)
CONTROL_SERVER_API_KEY=

# ── Observability ────────────────────────────────────────────────────────────

# Sentry DSN for error tracking. Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Database Pooling ────────────────────────────────────────────────────────────

# Connection pool tuning (uses psycopg2 ThreadedConnectionPool when present)
DATABASE_POOL_MINCONN=1
DATABASE_POOL_MAXCONN=5
DATABASE_CONNECT_TIMEOUT=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
